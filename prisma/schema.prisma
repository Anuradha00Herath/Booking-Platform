generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String
  name         String
  refreshToken String? // hashed refresh token
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

model Service {
  id          String    @id @default(uuid())
  title       String
  description String
  duration    Int // duration in minutes
  price       Decimal   @db.Decimal(10, 2)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  bookings    Booking[]

  @@map("services")
}

model Booking {
  id            String        @id @default(uuid())
  customerName  String
  customerEmail String
  customerPhone String
  serviceId     String
  service       Service       @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  bookingDate   DateTime      @db.Date
  bookingTime   String // HH:mm (24h)
  status        BookingStatus @default(PENDING)
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Prevents double-booking a slot: enforced in the DB via a partial unique
  // index (see migrations/..._active_booking_slot_unique) covering only
  // non-CANCELLED bookings, since Prisma's schema can't express a WHERE
  // clause on @@unique. Do not run `prisma db push` against this table -
  // it would drop the partial index since it isn't represented here.
  @@index([serviceId, bookingDate, bookingTime])
  @@index([status])
  @@map("bookings")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}
